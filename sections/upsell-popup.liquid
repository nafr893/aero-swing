<div id="upsell-overlay" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.45);z-index:999998;"></div>
<div id="upsell-popup" class="upsell-popup" style="display:none;">
  <button class="upsell-popup__close" id="upsell-close-x" aria-label="Close">&#x2715;</button>
  <h2 class="upsell-popup__heading">{{ settings.upsell_heading | default: 'Increase your Aero-Bat usefulness and fun factor!' }}</h2>
  <div id="upsell-products" class="upsell-popup__products"></div>
  <button class="upsell-popup__decline" id="upsell-no-thanks">No Thanks</button>
</div>

<style>
.upsell-popup {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: #fff;
  padding: 28px 24px 20px;
  border-radius: 12px;
  z-index: 999999;
  width: 90vw;
  max-width: 500px;
  text-align: center;
  box-shadow: 0 8px 40px rgba(0,0,0,0.18);
}
.upsell-popup__close {
  position: absolute;
  top: 10px;
  right: 14px;
  background: none;
  border: none;
  font-size: 18px;
  cursor: pointer;
  color: #666;
  line-height: 1;
  padding: 4px;
}
.upsell-popup__heading {
  font-size: 1.5rem !important;
  font-weight: 700;
  margin: 0 0 18px;
}
.upsell-popup__products {
  display: flex;
  gap: 14px;
  justify-content: center;
  margin-bottom: 16px;
}
.upsell-popup__card {
  flex: 1;
  border: 1px solid #e0e0e0;
  border-radius: 10px;
  padding: 14px 10px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}
.upsell-popup__card.is-unavailable { opacity: 0.55; }
.upsell-popup__card img { width: 80px; height: 80px; object-fit: contain; }
.upsell-popup__title { font-size: 1.15rem !important; font-weight: 600; margin: 0; }
.upsell-popup__price { font-size: 1.15rem !important; margin: 0; }
.upsell-popup__compare { color: #999; margin-right: 4px; }
.upsell-popup__sale { color: #c00; font-weight: 600; }
.upsell-popup__add-btn {
  background: #2D9712;
  color: #fff;
  border: none;
  border-radius: 6px;
  padding: 8px 14px;
  font-size: 0.85rem;
  font-weight: 600;
  cursor: pointer;
  width: 100%;
  margin-top: auto;
}
.upsell-popup__add-btn:disabled { background: #ccc; cursor: not-allowed; }
.upsell-popup__decline {
  background: none;
  border: none;
  color: #999;
  font-size: 1.1rem !important;
  cursor: pointer;
  text-decoration: underline;
  margin-top: 4px;
}
@media (max-width: 480px) {
  .upsell-popup__products { flex-direction: column; }
}
</style>

<script>
(function() {
  const BAT_HANDLE  = {{ settings.upsell_bat_handle | json }};
  const BALL_HANDLE = {{ settings.upsell_ball_handle | json }};
  const SALE_PRICE  = {{ settings.upsell_ball_sale_price | json }};

  if (!BAT_HANDLE || !BALL_HANDLE) return;

  function deleteCookie(name) {
    document.cookie = name + '=; expires=Thu, 01 Jan 1970 00:00:00 GMT; path=/';
  }

  const overlay    = document.getElementById('upsell-overlay');
  const popup      = document.getElementById('upsell-popup');
  const productsEl = document.getElementById('upsell-products');

  function fmt(cents) {
    return (cents / 100).toLocaleString('en-US', {style:'currency', currency:'USD'});
  }

  function buildCard(optionValue, variant, productImage) {
    const available = variant ? variant.available : false;
    const img = productImage
      ? `<img src="${productImage}" alt="${optionValue}" width="80" height="80" loading="lazy">`
      : '';

    let priceHtml;
    if (SALE_PRICE && variant) {
      priceHtml = `<p class="upsell-popup__price"><s class="upsell-popup__compare">${fmt(variant.price)}</s> <span class="upsell-popup__sale">$${SALE_PRICE}</span></p>`;
    } else if (variant && variant.compare_at_price > variant.price) {
      priceHtml = `<p class="upsell-popup__price"><s class="upsell-popup__compare">${fmt(variant.compare_at_price)}</s> <span class="upsell-popup__sale">${fmt(variant.price)}</span></p>`;
    } else {
      priceHtml = `<p class="upsell-popup__price">${variant ? fmt(variant.price) : ''}</p>`;
    }

    const card = document.createElement('div');
    card.className = 'upsell-popup__card' + (available ? '' : ' is-unavailable');
    card.dataset.variantId = variant ? variant.id : '';
    card.innerHTML = `
      ${img}
      <p class="upsell-popup__title">${optionValue}</p>
      ${priceHtml}
      <button class="upsell-popup__add-btn" ${available ? '' : 'disabled'}>
        ${available ? 'Add to Cart' : 'Out of Stock'}
      </button>
    `;
    card.querySelector('.upsell-popup__add-btn').addEventListener('click', async () => {
      const variantId = Number(card.dataset.variantId);
      if (!variantId) return;
      closePopup();
      setCookie('upsell_declined', 'true', 3);
      try {
        const res = await fetch('/cart/add.js', {
          method: 'POST',
          headers: {'Content-Type': 'application/json', 'Accept': 'application/json'},
          body: JSON.stringify({id: variantId, quantity: 1, sections: ['cart-drawer']})
        });
        window.FoxThemeEvents?.emit('ON_ITEM_ADDED', await res.json());
      } catch(e) {}
    });
    return card;
  }

  let productsReady = false;

  async function loadAndRenderProducts() {
    if (productsReady) return;
    try {
      const product = await fetch('/products/' + BALL_HANDLE + '.js').then(r => r.json());

      const seen = new Set();
      const option1Values = [];
      product.variants.forEach(v => {
        if (!seen.has(v.option1)) { seen.add(v.option1); option1Values.push(v.option1); }
      });

      option1Values.forEach(optVal => {
        const variant = product.variants.find(v => v.option1 === optVal && v.available)
                     || product.variants.find(v => v.option1 === optVal);
        const img = (variant && variant.featured_image)
          ? variant.featured_image.src
          : product.featured_image;
        productsEl.appendChild(buildCard(optVal, variant, img));
      });

      productsReady = true;
    } catch(e) {}
  }

  function openPopup() {
    overlay.style.display = 'block';
    popup.style.display   = 'block';
    if (!productsReady) loadAndRenderProducts();
  }

  function closePopup() {
    overlay.style.display = 'none';
    popup.style.display   = 'none';
  }

  async function fetchCartAndShowUpsell() {
    try {
      const cart    = await fetch('/cart.js').then(r => r.json());
      const hasBat  = cart.items.some(item => item.handle === BAT_HANDLE);
      const hasBall = cart.items.some(item => item.handle === BALL_HANDLE);
      if (!hasBat) { deleteCookie('upsell_declined'); closePopup(); return; }
      if (!hasBall && getCookie('upsell_declined') !== 'true') openPopup();
    } catch(e) {}
  }

  document.addEventListener('DOMContentLoaded', () => {
    const decline = () => { setCookie('upsell_declined', 'true', 3); closePopup(); };
    document.getElementById('upsell-no-thanks').addEventListener('click', decline);
    document.getElementById('upsell-close-x').addEventListener('click', decline);
    overlay.addEventListener('click', decline);
    popup.addEventListener('click', e => e.stopPropagation());

    document.body.addEventListener('submit', e => {
      if (e.target.matches('form[action^="/cart/add"]')) setTimeout(fetchCartAndShowUpsell, 700);
    });
    document.addEventListener('system-builder:item-added', () => setTimeout(fetchCartAndShowUpsell, 700));

    const setupFox = () => window.FoxThemeEvents?.subscribe?.('ON_ITEM_ADDED', () => setTimeout(fetchCartAndShowUpsell, 700));
    if (window.FoxThemeEvents) setupFox();
    else window.addEventListener('load', setupFox, {once: true});

    const cartDrawer = document.querySelector('cart-drawer, .cart-drawer, #CartDrawer');
    if (cartDrawer) new MutationObserver(() => fetchCartAndShowUpsell()).observe(cartDrawer, {childList: true, subtree: true});

    loadAndRenderProducts();
    fetchCartAndShowUpsell();
  });
})();
</script>
