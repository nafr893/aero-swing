{%- liquid
  assign addon_product = block.settings.addon_product
  if addon_product == blank
    echo nil
  endif
  assign first_variant = addon_product.selected_or_first_available_variant
  assign addon_option_name = addon_product.options[0] | downcase | strip
  assign addon_is_color = false
  if addon_option_name == 'color'
    assign addon_is_color = true
  endif
  assign override_price_cents = block.settings.override_price | times: 100 | round
  assign addon_is_multi = false
  if addon_product.options.size > 1
    assign addon_is_multi = true
  endif
-%}

{%- if addon_product != blank -%}
<product-addon
  class="product-addon"
  data-product-id="{{ addon_product.id }}"
  data-section-id="{{ section.id }}"
  data-main-product-id="{{ product.id }}"
  {% if override_price_cents > 0 %}data-override-price="{{ override_price_cents }}"{% endif %}>

  <div class="product-addon__card">
    <div class="product-addon__main">

      <div class="product-addon__image-wrap">
        {%- if addon_product.featured_image -%}
          <img
            src="{{ addon_product.featured_image | image_url: width: 120 }}"
            alt="{{ addon_product.featured_image.alt | default: addon_product.title | escape }}"
            width="60"
            height="60"
            loading="lazy">
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>

      <div class="product-addon__info">
        <p class="product-addon__title">{{ addon_product.title }}</p>

        {%- if addon_product.variants.size > 1 -%}
          {%- if addon_is_multi -%}

            <div class="product-addon__selects">
              {%- for opt in addon_product.options_with_values -%}
                {%- liquid
                  case forloop.index0
                    when 0
                      assign selected_opt_val = first_variant.option1
                    when 1
                      assign selected_opt_val = first_variant.option2
                    when 2
                      assign selected_opt_val = first_variant.option3
                  endcase
                -%}
                <div class="product-addon__select-wrap">
                  <label class="product-addon__select-label">{{ opt.name }}</label>
                  <div class="product-addon__select-inner">
                    <select class="product-addon__select" data-addon-select data-option-index="{{ forloop.index0 }}">
                      {%- for val in opt.values -%}
                        <option value="{{ val | escape }}"{% if val == selected_opt_val %} selected{% endif %}>{{ val }}</option>
                      {%- endfor -%}
                    </select>
                    <span class="product-addon__select-arrow">&#8964;</span>
                  </div>
                </div>
              {%- endfor -%}
            </div>

          {%- else -%}

            <p class="product-addon__selected-color" data-selected-color data-option-label="{{ addon_product.options[0] | escape }}"><span class="product-addon__option-label">{{ addon_product.options[0] }}:</span> {{ first_variant.option1 }}</p>
            <div class="product-addon__swatches-row">
              <div class="product-addon__swatches">
                {%- for variant in addon_product.variants -%}
                  {%- if addon_is_color -%}
                    <button
                      type="button"
                      class="product-addon__swatch{% if forloop.first %} is-selected{% endif %}"
                      data-swatch
                      data-variant-id="{{ variant.id }}"
                      title="{{ variant.option1 | escape }}"
                      data-color-value="{{ variant.option1 | escape }}"
                      {% unless variant.available %}data-sold-out="true"{% endunless %}
                    ></button>
                  {%- else -%}
                    <button
                      type="button"
                      class="product-addon__swatch product-addon__swatch--text{% if forloop.first %} is-selected{% endif %}"
                      data-swatch
                      data-variant-id="{{ variant.id }}"
                      title="{{ variant.option1 | escape }}"
                      data-color-value="{{ variant.option1 | escape }}"
                      {% unless variant.available %}data-sold-out="true"{% endunless %}
                    >{{ variant.option1 }}</button>
                  {%- endif -%}
                {%- endfor -%}
              </div>
              <div class="product-addon__swatches-nav">
                <button type="button" class="product-addon__swatches-btn" data-swatches-prev aria-label="Previous">&#8249;</button>
                <button type="button" class="product-addon__swatches-btn" data-swatches-next aria-label="Next">&#8250;</button>
              </div>
            </div>

          {%- endif -%}
        {%- endif -%}

        {%- if block.settings.description != blank -%}
          <p class="product-addon__desc">{{ block.settings.description }}</p>
        {%- endif -%}

        <p class="product-addon__price" data-addon-price>
          {%- if override_price_cents > 0 -%}
            {{ override_price_cents | money }}
          {%- else -%}
            {{ first_variant.price | money }}
          {%- endif -%}
        </p>
      </div>

    </div>

    <div class="product-addon__footer">
      <button type="button" class="product-addon__add-btn" data-add-btn>
        Add +
      </button>
    </div>

    <div class="product-addon__added-row" aria-hidden="true">
      <span class="product-addon__added-label">Added &mdash; <span data-added-price></span></span>
      <div class="product-addon__qty-controls">
        <button type="button" class="product-addon__qty-btn" data-qty-minus aria-label="Decrease quantity">&minus;</button>
        <span class="product-addon__qty-num" data-qty-display>1</span>
        <button type="button" class="product-addon__qty-btn" data-qty-plus aria-label="Increase quantity">+</button>
      </div>
      <button type="button" class="product-addon__remove" data-remove-btn>Remove</button>
    </div>
  </div>

  <script type="application/json" data-variants-json>
    {{ addon_product.variants | json }}
  </script>
</product-addon>
{%- endif -%}
