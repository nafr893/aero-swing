      return;
    }

    document.querySelectorAll('[data-enable-slider="false"]').forEach(slider => {
      new Flickity(slider, {
        cellSelector: '.f-column',
        wrapAround: true,
        groupCells: 4,
        pageDots: false,
        prevNextButtons: false
      });
    });
  });
});


